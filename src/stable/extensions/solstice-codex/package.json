{
  "name": "solstice-codex",
  "displayName": "Solstice Agent",
  "description": "Built-in AI agent panel powered by Codex (ChatGPT subscription).",
  "version": "0.3.0",
  "publisher": "solstice",
  "license": "MIT",
  "engines": {
    "vscode": "^1.121.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "capabilities": {
    "virtualWorkspaces": false,
    "untrustedWorkspaces": {
      "supported": false
    }
  },
  "contributes": {
    "viewsContainers": {
      "secondarySidebar": [
        {
          "id": "solstice-agent",
          "title": "Solstice Agent",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "solstice-agent": [
        {
          "type": "webview",
          "id": "solstice.agentPanel",
          "name": "Agent"
        }
      ]
    },
    "commands": [
      {
        "command": "solstice.agent.newThread",
        "title": "New Agent Thread",
        "category": "Solstice",
        "icon": "$(add)"
      },
      {
        "command": "solstice.agent.showDiff",
        "title": "Show Last Turn Diff",
        "category": "Solstice",
        "icon": "$(diff)"
      },
      {
        "command": "solstice.agent.signOut",
        "title": "Sign out of ChatGPT",
        "category": "Solstice"
      },
      {
        "command": "solstice.agent.openManager",
        "title": "Open Agent Manager",
        "category": "Solstice",
        "icon": "$(layout)"
      },
      {
        "command": "solstice.agent.openPreview",
        "title": "Preview Site",
        "category": "Solstice",
        "icon": "$(globe)"
      },
      {
        "command": "solstice.agent.selectModel",
        "title": "Select Agent Model",
        "category": "Solstice",
        "icon": "$(chip)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "solstice.agent.newThread",
          "when": "view == solstice.agentPanel",
          "group": "navigation@1"
        },
        {
          "command": "solstice.agent.showDiff",
          "when": "view == solstice.agentPanel",
          "group": "navigation@2"
        },
        {
          "command": "solstice.agent.openManager",
          "when": "view == solstice.agentPanel",
          "group": "navigation@3"
        },
        {
          "command": "solstice.agent.openPreview",
          "when": "view == solstice.agentPanel",
          "group": "navigation@4"
        },
        {
          "command": "solstice.agent.selectModel",
          "when": "view == solstice.agentPanel",
          "group": "navigation@5"
        }
      ]
    },
    "configuration": {
      "title": "Solstice Agent",
      "properties": {
        "solstice.codex.provider": {
          "type": "string",
          "enum": [
            "gpt-5.5",
            "claude",
            "grok-build",
            "composer-2.5"
          ],
          "enumDescriptions": [
            "GPT-5.5 via the codex CLI (ChatGPT subscription) — full agent",
            "Claude Code via the claude CLI (Anthropic Max subscription) — fleet engine",
            "Grok 4.3 Build via the grok CLI — agentic fallback",
            "Composer 2.5 Fast via the grok CLI — fast builder"
          ],
          "default": "gpt-5.5",
          "description": "Which model drives the Solstice agent. Switch to claude or a grok-CLI model when the Codex usage limit is hit."
        },
        "solstice.codex.path": {
          "type": "string",
          "default": "",
          "description": "Path to the codex binary. Empty = bundled binary, then PATH."
        },
        "solstice.codex.home": {
          "type": "string",
          "default": "",
          "description": "CODEX_HOME directory for auth/config. Empty = codex default (~/.codex)."
        },
        "solstice.codex.model": {
          "type": "string",
          "default": "gpt-5.5",
          "description": "Model for agent threads."
        },
        "solstice.codex.approvalPolicy": {
          "type": "string",
          "enum": [
            "untrusted",
            "on-request",
            "on-failure",
            "never"
          ],
          "default": "on-request",
          "description": "When the agent must ask before running commands."
        },
        "solstice.codex.sandbox": {
          "type": "string",
          "enum": [
            "read-only",
            "workspace-write",
            "danger-full-access"
          ],
          "default": "workspace-write",
          "description": "Sandbox policy for agent commands."
        },
        "solstice.codex.claudePath": {
          "type": "string",
          "default": "",
          "description": "Path to the claude binary (Claude Code CLI). Empty = `claude` from PATH."
        },
        "solstice.codex.claudePermissionMode": {
          "type": "string",
          "enum": [
            "acceptEdits",
            "default",
            "dontAsk",
            "bypassPermissions"
          ],
          "default": "acceptEdits",
          "description": "Permission mode passed to the claude CLI. In headless --print mode tools that would prompt are denied; raise to bypassPermissions if shell commands get blocked."
        }
      }
    }
  }
}
